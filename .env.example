# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Provider (DeepSeek — OpenAI-compatible)
OPENAI_API_KEY=sk-your_deepseek_api_key

# Site URL
NEXT_PUBLIC_SITE_URL=https://rixin.velolabs.top

# Push Notifications (VAPID)
# Generate with: npx web-push generate-vapid-keys
# See: https://www.npmjs.com/package/web-push
NEXT_PUBLIC_VAPID_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=your_email@example.com
