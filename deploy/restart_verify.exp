#!/usr/bin/expect -f

set timeout 120

spawn ssh ubuntu@118.25.141.173
expect "password:"
send "Chris@1989\r"

expect -re {\$ |# }
send "sudo pm2 restart rixin --update-env 2>&1\r"

expect -re {\$ |# }
send "sleep 5 && curl -s -o /dev/null -w '%{http_code}' http://localhost:3000 && echo ''\r"

expect {
    "200" {
        puts "\n=== SERVER HEALTHY (200) ==="
    }
    timeout {
        puts "\n=== HEALTH CHECK TIMEOUT ==="
    }
}

expect -re {\$ |# }
send "exit\r"

expect eof
